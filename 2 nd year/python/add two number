#         self.val = val
#         self.next = next

class Solution(object):
    def addTwoNumbers(self, l1, l2):
        """
        :type l1: ListNode
        :type l2: ListNode
        :rtype: ListNode
        """
        # Dummy head helps simplify the code for the first node
        dummy = ListNode(0)
        curr = dummy
        carry = 0
        
        # Continue as long as there are nodes to process or a carry exists
        while l1 or l2 or carry:
            # Get values from nodes, or 0 if the list has ended
            val1 = l1.val if l1 else 0
            val2 = l2.val if l2 else 0
            
            # Calculate total and carry
            total = val1 + val2 + carry
            carry = total // 10
            
            # Create new node with the single digit
            curr.next = ListNode(total % 10)
            
            # Move pointers forward
            curr = curr.next
            if l1: l1 = l1.next
            if l2: l2 = l2.next
            
        return dummy.next
