class Solution:
    def countAndSay(self, n: int) -> str:
        # Base case: the sequence starts with "1"
        res = "1"
        
        # Generate the sequence n-1 times
        for _ in range(n - 1):
            next_res = []
            i = 0
            
            # Use two pointers to count consecutive identical digits
            while i < len(res):
                count = 1
                # While the next digit is the same, increment the count
                while i + 1 < len(res) and res[i] == res[i + 1]:
                    count += 1
                    i += 1
                
                # Append the count and the digit to the next result
                next_res.append(str(count))
                next_res.append(res[i])
                i += 1
            
            # Join the list into a string for the next iteration
            res = "".join(next_res)
            
        return res

# Example 1: n = 4 -> Output: "1211"
# Example 2: n = 1 -> Output: "1"
